{
    "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/nx-schema.json",
    "targetDefaults": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "cache": true
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": [
                "build"
            ]
        },
        "lint": {
            "cache": true
        }
    }
}